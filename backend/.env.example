# B Bot is intentionally locked to Bybit Demo Trading.
ENVIRONMENT=demo
BYBIT_REST_URL=https://api-demo.bybit.com
BYBIT_PUBLIC_WS_URL=wss://stream.bybit.com/v5/public/linear
BYBIT_PRIVATE_WS_URL=wss://stream-demo.bybit.com/v5/private
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Replit PostgreSQL: use the DATABASE_URL secret supplied by Replit.
# Local fallback:
DATABASE_URL=sqlite:///./data/bbot.db

BOT_TRADING_CAPITAL=1000
RISK_FRACTION=0.01
MAX_OPEN_TRADES=3
MAX_LEVERAGE=5
COOLDOWN_HOURS=4
TIMEZONE=Asia/Dhaka
APP_ADMIN_TOKEN=
FRONTEND_ORIGIN=*
REAL_MODE_ENABLED=false
# Used only when Demo does not expose the account fee-rate endpoint.
TAKER_FEE_RATE_DEFAULT=0.0006
