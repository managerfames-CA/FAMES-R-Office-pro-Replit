modules = ["nodejs-24", "python-3.11", "postgresql-16"]

run = "bash scripts/run-bbot.sh"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "python -m pip install -r requirements.txt && corepack enable && pnpm install --frozen-lockfile && pnpm run build:ui"]
run = ["sh", "-c", "python main.py"]

[workflows]
runButton = "B Bot"

[[workflows.workflow]]
name = "B Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/run-bbot.sh"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 8000
externalPort = 80

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[nix]
channel = "stable-25_05"
